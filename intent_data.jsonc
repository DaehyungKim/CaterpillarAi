  { "text": "예약 걸어둔 거 취소해줘.", "label": 31 },
  { "text": "잘못 예약했는데 취소 가능할까요?", "label": 31 },
  { "text": "예약 목록에서 이 책 좀 빼주세요.", "label": 31 },

  { "text": "저 연체된 책 있나요?", "label": 32 },
  { "text": "연체료가 얼마인지 확인해주세요.", "label": 32 },
  { "text": "연체 때문에 대출 정지됐는지 확인해줘.", "label": 32 },
  { "text": "제 연체 기록 좀 확인하고 싶어요.", "label": 32 },
  { "text": "반납일 지난 책 없는지 확인해주세요.", "label": 32 },
  { "text": "연체 일수랑 연체료 알려줘.", "label": 32 },
  { "text": "혹시 연체된 내역 있는지 알려주세요.", "label": 32 },
  { "text": "연체료 내야 하나요?", "label": 32 },

  { "text": "회원증을 잃어버렸어요. 어떻게 해야 하나요?", "label": 33 },
  { "text": "회원증 분실 신고할게요.", "label": 33 },
  { "text": "도서관 카드를 잃어버렸어요.", "label": 33 },
  { "text": "분실물 신고 어디서 하나요?", "label": 33 },

  { "text": "안녕하세요", "label": 34 },
  { "text": "안녕", "label": 34 },
  { "text": "반가워요", "label": 34 },
  { "text": "좋은 아침입니다", "label": 34 },
  { "text": "하이", "label": 34 },
  { "text": "ㅎㅇ", "label": 34 },
  { "text": "반갑습니다", "label": 34 },
  { "text": "안녕하세요?", "label": 34 },

  { "text": "고마워요", "label": 35 },
  { "text": "감사합니다", "label": 35 },
  { "text": "도와줘서 고마워", "label": 35 },
  { "text": "덕분입니다", "label": 35 },
  { "text": "땡큐", "label": 35 },
  { "text": "ㄱㅅ", "label": 35 },
  { "text": "정말 감사합니다.", "label": 35 },
  { "text": "친절한 답변 고마워요.", "label": 35 },

  { "text": "이제 그만할게요", "label": 36 },
  { "text": "안녕히 계세요", "label": 36 },
  { "text": "다음에 또 봐요", "label": 36 },
  { "text": "됐어요", "label": 36 },
  { "text": "바이", "label": 36 },
  { "text": "종료", "label": 36 },
  { "text": "나중에 다시 올게요.", "label": 36 },
  { "text": "수고하세요.", "label": 36 },

  { "text": "네", "label": 37 },
  { "text": "맞아요", "label": 37 },
  { "text": "좋아요", "label": 37 },
  { "text": "그렇게 해주세요", "label": 37 },
  { "text": "응", "label": 37 },
  { "text": "ㅇㅇ", "label": 37 },
  { "text": "알겠습니다", "label": 37 },
  { "text": "네, 맞습니다.", "label": 37 },

  { "text": "아니요", "label": 38 },
  { "text": "아니에요", "label": 38 },
  { "text": "싫어요", "label": 38 },
  { "text": "됐어요", "label": 38 },
  { "text": "아니", "label": 38 },
  { "text": "ㄴㄴ", "label": 38 },
  { "text": "그건 아니에요.", "label": 38 },
  { "text": "괜찮아요 (거절)", "label": 38 },

  { "text": "뭐라는 거야?", "label": 39 },
  { "text": "답답하네 진짜", "label": 39 },
  { "text": "제대로 좀 해봐", "label": 39 },
  { "text": "야!", "label": 39 },
  { "text": "이 바보야", "label": 39 },
  { "text": "멍청하긴", "label": 39 },
  { "text": "말귀를 못 알아듣네", "label": 39 },
  { "text": "장난해?", "label": 39 },

  { "text": "무슨 말인지 잘 모르겠어요", "label": 40 },
  { "text": "다시 한번 설명해줄래요?", "label": 40 },
  { "text": "그게 무슨 뜻이죠?", "label": 40 },
  { "text": "좀 더 자세히 알려줘", "label": 40 },
  { "text": "뭐라고?", "label": 40 },
  { "text": "이해가 안 가요", "label": 40 },
  { "text": "방금 말한 거 다시 설명해줘.", "label": 40 },

  { "text": "오늘 날씨 어때?", "label": 41 },
  { "text": "근처 맛집 추천해줘", "label": 41 },
  { "text": "나 심심한데 놀아줘", "label": 41 },
  { "text": "로또 번호 알려줘", "label": 41 },
  { "text": "지금 몇 시야?", "label": 41 },
  { "text": "사랑이 뭘까?", "label": 41 },
  { "text": "노래 불러줘", "label": 41 },
  { "text": "여기 와이파이 비밀번호 말고 내 핸드폰 데이터 요금제 추천해줘", "label": 41 },

  { "text": "방금 뭐라고 했어?", "label": 42 },
  { "text": "다시 말해줄래?", "label": 42 },
  { "text": "못 들었어, 다시 한번", "label": 42 },
  { "text": "한 번 더 알려줘.", "label": 42 },
  { "text": "다시 한번 말해주세요.", "label": 42 },
  { "text": "뭐라고 했는지 다시 알려줘.", "label": 42 },
  { "text": "이전 답변 다시 보여줘.", "label": 42 },
  { "text": "방금 내용 다시 말해봐.", "label": 42 }
]
