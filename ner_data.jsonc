[
  //title -------------------------------------------------------------
  {
    "text": "이기적 유전자 찾아줘",
    "entities": [[0, 7, "title"]]
  },
  {
    "text": "미움받을 용기 책 있는지 찾아봐 줘",
    "entities": [
      [0, 7, "title"],
      [8, 9, "format"]
    ]
  },
  {
    "text": "총, 균, 쇠라는 책 검색해줘",
    "entities": [
      [0, 7, "title"],
      [10, 11, "format"]
    ]
  },
  {
    "text": "사람은 무엇으로 사는가 책 있어?",
    "entities": [
      [0, 12, "title"],
      [13, 14, "format"]
    ]
  },
  {
    "text": "데일 카네기의 인간관계론 검색해줘",
    "entities": [
      [0, 13, "title"]
    ]
  },
  {
    "text": "불편한 편의점 도서 검색",
    "entities": [
      [0, 7, "title"],
      [8, 10, "format"]
    ]
  },
  {
    "text": "아프니까 청춘이다 찾아줄래?",
    "entities": [
      [0, 9, "title"]
    ]
  },
  {
    "text": "사피엔스 : 그래픽 히스토리 Vol.1라는 책 있나요?",
    "entities": [
      [0, 21, "title"],
      [24, 25, "format"]
    ]
  },
  {
    "text": "마음이 요동칠 때, 기꺼이 나는 혼자가 된다 책 찾아주세요.",
    "entities": [
      [0, 24, "title"],
      [25, 26, "format"]
    ]
  },
  {
    "text": "예술에 대한 여덟 가지 답변의 역사 소장하고 있는지 궁금합니다.",
    "entities": [
      [0, 19, "title"]
    ]
  },
  {
    "text": "벌거벗은 세계사 : 과학편 검색해줘.",
    "entities": [
      [0, 14, "title"]

    ]
  },
  {
    "text": "버터밀크 그래피티 구비되어 있는지 확인할 수 있을까요?",
    "entities": [
      [0, 9, "title"]
    ]
  },
  {
    "text": "만화로 배우는 멸종과 진화 도서관에 있어요?",
    "entities": [
      [0, 14, "title"]

    ]
  },
  {
    "text": "명상록 책 지금 볼 수 있나요?",
    "entities": [
      [0, 3, "title"],
      [4, 5, "format"]
    ]
  },
  {
    "text": "암기 없이 그림으로 이해되는 수학 개념 사전 찾고 싶은데 어디 있나요?",
    "entities": [
      [0, 24, "title"]
    ]
  },
  {
    "text": "다시, 공부머리 독서법 : 영유아, 초등 저학년 편 책 제목으로 검색해주세요.",
    "entities": [
      [0, 28, "title"],
      [29, 30, "format"]
    ]
  },
  {
    "text": "듀얼 브레인 비치되어 있나요?",
    "entities": [
      [0, 6, "title"]
    ]
  },
  {
    "text": "민족과 혁명 도서관에 있는지 알려줘.",
    "entities": [
      [0, 6, "title"]

    ]
  },
  {
    "text": "교토커피 보유 중인지 궁금해요.",
    "entities": [
      [0, 4, "title"]

    ]
  },
  {
    "text": "참을 수 없는 건 사랑인 걸까 1 제목으로 책 검색 좀 해주세요.",
    "entities": [
      [0, 18, "title"],
      [24, 25, "format"]
    ]
  },
  {
    "text": "수학의 중력이라는 제목의 책 있나 확인하고 싶어요.",
    "entities": [
      [0, 6, "title"],
      [14, 15, "format"]
    ]
  },
  {
    "text": "계급의 숨은 상처라는 책 소장 여부 확인 가능할까요?",
    "entities": [
      [0, 9, "title"],
      [12, 13, "format"]
    ]
  },
  {
    "text": "혹시 검은 불꽃과 빨간 폭스바겐 찾을 수 있을까요?",
    "entities": [
      [3, 17, "title"]
    ]
  },
  {
    "text": "여행자를 위한 교토 답사기라는 책 보유하고 계신가요?",
    "entities": [
      [0, 14, "title"],
      [17, 18, "format"]
    ]
  },
  {
    "text": "도넛을 나누는 기분 제목이 생각나는데 그 책 있나요?",
    "entities": [
      [0, 10, "title"],
      [23, 24, "format"]
    ]
  },
  {
    "text": "사랑과 시간의 알레고리 도서관에 갖고 계신지요?",
    "entities": [
      [0, 12, "title"]
    ]
  },
  {
    "text": "돈덴이라는 책 도서관에서 찾을 수 있을까요?",
    "entities": [
      [0, 2, "title"],
      [6, 7, "format"]
    ]
  },
  {
    "text": "주술회전 29 책 검색 결과 알려주세요.",
    "entities": [
      [0, 7, "title"],
      [8, 9, "format"]
    ]
  },
  {
    "text": "너에게 들려주는 단단한 말 책 정보 좀 주세요.",
    "entities": [
      [0, 14, "title"],
      [15, 16, "format"]
    ]
  },
  {
    "text": "COLOR & LIGHT 책 재고 있나요?",
    "entities": [
      [0, 13, "title"],
      [14, 15, "format"]
    ]
  },
  {
    "text": "거울나라의 앨리스 찾으려는데 검색 부탁드립니다.",
    "entities": [
      [0, 9, "title"]
    ]
  },
  {
    "text": "나의 한국현대사 1959-2020 소장 도서 목록에 있나요?",
    "entities": [
      [0, 18, "title"],
      [22, 24, "format"]
    ]
  },
  {
    "text": "절대 진공 & 상상된 위대함 책명으로 도서 검색 원합니다.",
    "entities": [
      [0, 15, "title"],
      [16, 17, "format"],
      [21, 23, "format"]
    ]
  },
  {
    "text": "너에게 들려주는 단단한 말 있나 한번 봐줄래요?",
    "entities": [
      [0, 14, "title"]
    ]
  },
  {
    "text": "면도날 그거 책으로 있나요?",
    "entities": [
      [0, 3, "title"],
      [7, 8, "format"]
    ]
  },
  {
    "text": "에이든 리스본ㆍ포르투 포르투갈 여행지도 2025-2026 혹시 도서관에 있어?",
    "entities": [
      [0, 31, "title"]
    ]
  },
  {
    "text": "프렌즈 뉴욕 찾고 있는데 도서관에 있을까?",
    "entities": [
      [0, 6, "title"]
    ]
  },
  {
    "text": "경영의 길을 묻다 있으면 알려줘.",
    "entities": [
      [0, 9, "title"]
    ]
  },
  {
    "text": "마흔에 보는 그림 책 있으면 검색 좀 해줘.",
    "entities": [
      [0, 9, "title"],
      [10, 11, "format"]
    ]
  },
  {
    "text": "디스 이즈 미국 서부 This Is Western USA가 도서관에 있을지 몰라서 찾아보려구요.",
    "entities": [
      [0, 31, "title"]
    ]
  },
  {
    "text": "행복할 거야 이래도 되나 싶을 정도로 제목 생각났는데 도서관에 있나요?",
    "entities": [
      [0, 20, "title"]
    ]
  },
  {
    "text": "엔드 오브 타임 책으로 볼 수 있는지 확인해 줄래?",
    "entities": [
      [0, 8, "title"],
      [9, 10, "format"]
    ]
  },
  {
    "text": "노인과 바다 혹시 도서관에서 이용할 수 있나요?",
    "entities": [
      [0, 6, "title"]
    ]
  },
  {
    "text": "도서관에 있는 책 중에 김락희의 인체 드로잉 찾고 있어요.",
    "entities": [
      [13, 24, "title"],
      [8, 9, "format"]
    ]
  },
  {
    "text": "제가 찾는 책은 한밤중 하트튠 4인데요, 있나요?",
    "entities": [
      [9, 18, "title"],
      [6, 7, "format"]
    ]
  },
  {
    "text": "코스모스라는 책이 있는지 궁금해서요.",
    "entities": [
      [0, 4, "title"],
      [7, 8, "format"]
    ]
  },
  {
    "text": "지금 리얼 포르투갈이란 책이 도서관에 있는지 확인 가능할까요?",
    "entities": [
      [3, 11, "title"],
      [13, 14, "format"]
    ]
  },
  {
    "text": "손자병법이 도서관에 비치되어 있는지 알고 싶어요.",
    "entities": [
      [0, 4, "title"]
    ]
  },
  {
    "text": "혹시 사피엔스 같은 책도 소장 중이신가요?",
    "entities": [
      [3, 7, "title"],
      [11, 12, "format"]
    ]
  },
  {
    "text": "사피엔스 : 그래픽 히스토리 Vol.1 책, 지금 도서관에서 이용할 수 있나요?",
    "entities": [
      [0, 21, "title"],
      [22, 23, "format"]
    ]
  },
  {
    "text": "도서관에서 모든 계절의 물리학이라는 책을 찾을 수 있을까요?",
    "entities": [
      [6, 16, "title"],
      [20, 21, "format"]
    ]
  },
  {
    "text": "경영의 길을 묻다 소장 여부 좀 확인해주시겠어요?",
    "entities": [
      [0, 9, "title"]
    ]
  },
  {
    "text": "최근에 버터밀크 그래피티라는 책에 관심이 생겼는데, 도서관에 있을까요?",
    "entities": [
      [4, 13, "title"],
      [16, 17, "format"]
    ]
  },
  {
    "text": "명상록 읽어보려고 하는데 도서관에 있나 궁금합니다.",
    "entities": [
      [0, 3, "title"]
    ]
  },
  {
    "text": "친구가 디스 이즈 스위스 This is Swiss 괜찮다고 해서 도서관에 있는지 확인하려고요.",
    "entities": [
      [4, 27, "title"]
    ]
  },
  {
    "text": "에이든 국내여행 가이드북이라는 책을 과제 때문에 꼭 읽어야 하는데, 혹시 도서관에 있을까요?",
    "entities": [
      [0, 13, "title"],
      [17, 18, "format"]
    ]
  },
  {
    "text": "수업 시간에 방구석 미술관 3 이야기가 나와서 찾아보려는데 도서관에 있나요?",
    "entities": [
      [0, 16, "title"]
    ]
  },
  {
    "text": "이 지랄맞음이 쌓여 축제가 되겠지 도서관에서 볼 수 있으면 좋겠는데, 있나요?",
    "entities": [
      [0, 18, "title"]
    ]
  },
  {
    "text": "브람스를 좋아하세요 읽고 싶은데 도서관에도 있을지 모르겠네요.",
    "entities": [
      [0, 10, "title"]
    ]
  },
  {
    "text": "도서관에서 만화로 배우는 멸종과 진화 책이 있는지 확인 좀 해주세요.",
    "entities": [
      [6, 20, "title"],
      [21, 22, "format"]
    ]
  },
  {
    "text": "하와이 렌터카 여행이란 제목의 책이 필요합니다. 있나요?",
    "entities": [
      [0, 12, "title"],
      [17, 18, "format"]
    ]
  },
  {
    "text": "제가 찾는 책 중에 하나가 AI 2025인데, 혹시 비치되어 있을까요?",
    "entities": [
      [15, 22, "title"],
      [6, 7, "format"]
    ]
  },
  {
    "text": "이제야 보이네라는 도서를 소장하고 있는 도서관인지 궁금하네요.",
    "entities": [
      [0, 7, "title"],
      [10, 12, "format"]
    ]
  },
  {
    "text": "요즘 식물의 발칙한 사생활이라는 책이 인기가 많던데, 혹시 여기에도 있나요?",
    "entities": [
      [3, 14, "title"],
      [18, 19, "format"]
    ]
  },
  {
    "text": "엄마 생물학이라는 책을 추천받았는데, 도서관에 있는지 먼저 확인하려 합니다.",
    "entities": [
      [0, 6, "title"],
      [10, 11, "format"]
    ]
  },
  {
    "text": "당신의 세계는 아직도 바다와 빗소리와 작약을 취급하는지 책을 한 번 읽어보려고 해요. 혹시 여기 도서관에 있을까요?",
    "entities": [
      [0, 30, "title"],
      [31, 32, "format"]
    ]
  },
  {
    "text": "급류 그 책, 도서관에 비치되어 있으면 좋을 텐데요.",
    "entities": [
      [0, 2, "title"],
      [5, 6, "format"]
    ]
  },
  {
    "text": "나의 MBTI가 궁금하단 마리몽을 도서관에서 이용하고 싶은데 가능할지요?",
    "entities": [
      [0, 17, "title"]
    ]
  },
  {
    "text": "반려견 행동심리학이라는 자료를 찾고 있습니다. 소장 여부 확인 부탁드립니다.",
    "entities": [
      [0, 9, "title"],
      [12, 14, "format"]
    ]
  },
  {
    "text": "소설 보다 : 봄 2025 관련해서 책을 찾고 있는데, 혹시 해당 제목이 있는지요?",
    "entities": [
      [0, 14, "title"],
      [20, 21, "format"]
    ]
  },
  {
    "text": "이방인 그 책 있으면 좋겠는데, 확인 좀 해주실 수 있나요?",
    "entities": [
      [0, 3, "title"],
      [6, 7, "format"]
    ]
  },
  {
    "text": "그 개와 혁명이라는 책이 있는지, 검색해주시겠어요?",
    "entities": [
      [0, 7, "title"],
      [11, 12, "format"]
    ]
  },
  {
    "text": "우주여행자를 위한 생존법 도서관에서 구할 수 있으면 정말 도움이 될 것 같아요.",
    "entities": [
      [0, 13, "title"]
    ]
  },
  {
    "text": "도서관에 있는 책 중에 찾고 있는 건 하루메이 1요.",
    "entities": [
      [21, 27, "title"]
    ]
  },
  {
    "text": "혹시 소장 중인 책 목록에 정관스님 나의 음식도 포함되어 있나요?",
    "entities": [
      [15, 25, "title"],
      [9, 10, "format"]
    ]
  },
  {
    "text": "제가 찾는 건 돈덴이라는 제목의 책입니다.",
    "entities": [
      [8, 10, "title"],
      [18, 19, "format"]
    ]
  },
  {
    "text": "자료실에 비치된 책들 중에서 스토너를 찾고 있어요.",
    "entities": [
      [16, 19, "title"],
      [9, 10, "format"]
    ]
  },
  {
    "text": "도서 검색에서 손끝과 연연 11이 나오는지 확인하고 싶어요.",
    "entities": [
      [8, 17, "title"]
    ]
  },
  {
    "text": "필요한 책이 김락희의 인체 드로잉인데, 도서관에 있는지 알아봐 주세요.",
    "entities": [
      [7, 18, "title"],
      [4, 5, "format"]
    ]
  },
  {
    "text": "찾고 싶은 책 제목이 고독의 이야기들인데 혹시 있는지요?",
    "entities": [
      [12, 20, "title"],
      [6, 7, "format"]
    ]
  },
  {
    "text": "책장에 꽂혀 있는 것 중에 만국의 노동자여 글을 쓰자 확인 가능할까요?",
    "entities": [
      [15, 29, "title"]
    ]
  },
  {
    "text": "검색 키워드로 채식주의자를 입력했을 때 나오는 도서가 있나요?",
    "entities": [
      [8, 13, "title"],
      [26, 28, "format"]
    ]
  },
  {
    "text": "이용 가능한 도서 중에 고독의 이야기들 포함되어 있으면 알려 주세요.",
    "entities": [
      [13, 21, "title"],
      [7, 9, "format"]
    ]
  },
  {
    "text": "혹시 신간 목록에 버터밀크 그래피티가 포함되어 있나요?",
    "entities": [
      [10, 19, "title"]
    ]
  },
  {
    "text": "도서 요청하기 전에 콘클라베가 있는지부터 확인하고 싶어요.",
    "entities": [
      [11, 16, "title"],
      [0, 2, "format"]
    ]
  },
  {
    "text": "관심 있는 도서가 예술에 대한 여덟 가지 답변의 역사인데, 소장 여부가 궁금합니다.",
    "entities": [
      [10, 29, "title"],
      [6, 8, "format"]
    ]
  },
  {
    "text": "전공 도서 중에 스토너가 필요해서요.",
    "entities": [
      [9, 12, "title"],
      [3, 5, "format"]
    ]
  },
  {
    "text": "학교 추천 도서로 고독의 이야기들을 받았는데, 확인 부탁드려요.",
    "entities": [
      [10, 18, "title"],
      [6, 8, "format"]
    ]
  },
  {
    "text": "과제 때문에 계엄령이 꼭 필요합니다.",
    "entities": [
      [7, 10, "title"]
    ]
  },
  {
    "text": "친구가 빌렸던 책 중에 세상은 라틴어로 가득하다가 괜찮다고 하더라고요.",
    "entities": [
      [13, 26, "title"],
      [8, 9, "format"]
    ]
  },
  {
    "text": "도서 대출 전에 카구라바치 4를 확인해 보고 싶어요.",
    "entities": [
      [9, 16, "title"]
    ]
  },
  {
    "text": "요즘 많이 읽는 책 중에 우주여행자를 위한 생존법도 포함되나요?",
    "entities": [
      [14, 27, "title"],
      [9, 10, "format"]
    ]
  },
  {
    "text": "구입 희망 도서 신청 전 대온실 수리 보고서가 있는지부터 알아보고 싶습니다.",
    "entities": [
      [14, 24, "title"],
      [6, 8, "format"]
    ]
  },
  {
    "text": "혹시 지금 도서관에 나답게 살고 싶어서 뇌과학을 읽습니다 있나 알아봐 줄 수 있어요?",
    "entities": [
      [11, 31, "title"]
    ]
  },
  {
    "text": "찾아보려는 책 이름이 대만 현지 쇼핑 대백과인데, 도서관에 있을까요?",
    "entities": [
      [12, 24, "title"],
      [6, 7, "format"]
    ]
  },
  {
    "text": "자료 요청 전에 그 개와 혁명이 있는지부터 검색해 보려 합니다.",
    "entities": [
      [9, 16, "title"]
    ]
  },
  {
    "text": "어제 들은 책이 비실비실 선생님 5인데 도서관에 있는지 알아보고 싶어요.",
    "entities": [
      [9, 17, "title"],
      [6, 7, "format"]
    ]
  },
  {
    "text": "수업 때 언급된 책 중에 가요로 읽는 한국사가 생각나서요.",
    "entities": [
      [14, 24, "title"],
      [9, 10, "format"]
    ]
  },
  {
    "text": "참고 문헌 목록에 지리의 힘이 있었는데 도서관에서 볼 수 있을까요?",
    "entities": [
      [10, 15, "title"]
    ]
  },
  {
    "text": "교수님이 추천하신 책이 듀얼 브레인이라는데 도서관에 있을까요?",
    "entities": [
      [13, 19, "title"],
      [10, 11, "format"]
    ]
  },
  {
    "text": "야 잘할 거예요, 어디서든좀 찾아줘라",
    "entities": [
      [2, 14, "title"]
    ]
  },
  {
    "text": "나 크리스마스 캐럴 찾고 있는뎅",
    "entities": [
      [2, 10, "title"]
    ]
  },
  {
    "text": "도서관에 로미오와 줄리엣 있냐?",
    "entities": [
      [5, 13, "title"]
    ]
  },
  {
    "text": "야 도서관에 수학의 중력이라는 책 있냐?",
    "entities": [
      [7, 13, "title"],
      [17, 18, "format"]
    ]
  },


  //author -------------------------------------------------------------
  {
    "text": "무라카미 하루키가 쓴 책 있어?",
    "entities": [
      [0, 8, "author"],
      [12, 13, "format"]
    ]
  },
  {
    "text": "베르나르 베르베르 작가의 책들 좀 검색해줄래?",
    "entities": [
      [0, 9, "author"],
      [14, 15, "format"]
    ]
  },
  {
    "text": "김영하 작가 책 검색해주세요",
    "entities": [
      [0, 3, "author"],
      [7, 8, "format"]
    ]
  },
  {
    "text": "오스카 와일드의 소설 뭐가 있어?",
    "entities": [
      [0, 7, "author"]
    ]
  },
  {
    "text": "오르한 파묵이 쓴 책 목록 보여줘",
    "entities": [
      [0, 6, "author"],
      [10, 11, "format"]
    ]
  },
  {
    "text": "알랭 드 보통 저자의 책 있나요?",
    "entities": [
      [0, 7, "author"],
      [12, 13, "format"]
    ]
  },
  {
    "text": "정유정 작가 책 찾아줘",
    "entities": [
      [0, 3, "author"],
      [7, 8, "format"]
    ]
  },
  {
    "text": "공지영이 쓴 책 검색해줘",
    "entities": [
      [0, 3, "author"],
      [7, 8, "format"]
    ]
  },
  {
    "text": "도서관에 김범준 작가 책 있어?",
    "entities": [
      [5, 8, "author"],
      [12, 13, "format"]
    ]
  },
  {
    "text": "손성준 책 있어?",
    "entities": [
      [0, 3, "author"],
      [4, 5, "format"]
    ]
  },
  {
    "text": "히노하라 메구루 작가 책 있어?",
    "entities": [
      [0, 8, "author"],
      [12, 13, "format"]
    ]
  },
  {
    "text": "도서관에 말콤 글래드웰 책 있어?",
    "entities": [
      [5, 12, "author"],
      [13, 14, "format"]
    ]
  },
  {
    "text": "도서관에 캐시 윌리스 작가 책 있어?",
    "entities": [
      [5, 11, "author"],
      [15, 16, "format"]
    ]
  },
  {
    "text": "혹시 조지 오웰 작가가 쓴 책은 도서관에 있나요?",
    "entities": [
      [3, 8, "author"],
      [15, 16, "format"]
    ]
  },
  {
    "text": "NAOE 저자의 책 좀 찾아줄래?",
    "entities": [
      [0, 4, "author"],
      [9, 10, "format"]
    ]
  },
  {
    "text": "앙투안 드 생텍쥐페리라는 사람이 쓴 책을 찾고 싶은데, 도서관에 있을까?",
    "entities": [
      [0, 11, "author"],
      [20, 21, "format"]
    ]
  },
  {
    "text": "도서관에서 깡토 작품 찾을 수 있을까?",
    "entities": [
      [6, 8, "author"]
    ]
  },
  {
    "text": "피터 린치 책이 도서관에 있는지 확인해줄래?",
    "entities": [
      [0, 5, "author"],
      [6, 7, "format"]
    ]
  },
  {
    "text": "김태유 저자의 책 목록 볼 수 있어?",
    "entities": [
      [0, 3, "author"],
      [8, 9, "format"]
    ]
  },
  {
    "text": "모리시타 수가 쓴 책 중에 도서관에 있는 거 있어?",
    "entities": [
      [0, 6, "author"],
      [10, 11, "format"]
    ]
  },
  {
    "text": "아오야마 고쇼 작품이 도서관에 있는지 궁금해",
    "entities": [
      [0, 7, "author"]
    ]
  },
  {
    "text": "이케가야 유지라는 작가 책 좀 보여줄 수 있어?",
    "entities": [
      [0, 7, "author"],
      [13, 14, "format"]
    ]
  },
  {
    "text": "차란 란가나스 작가가 쓴 책 도서관에 들어왔는지 알아봐줘",
    "entities": [
      [0, 7, "author"],
      [14, 15, "format"]
    ]
  },
  {
    "text": "모죠 저자 관련 책 보관 중이야?",
    "entities": [
      [0, 2, "author"],
      [9, 10, "format"]
    ]
  },
  {
    "text": "도서관에 마쓰시타 고노스케 책 재고 있나?",
    "entities": [
      [5, 14, "author"],
      [15, 16, "format"]
    ]
  },
  {
    "text": "하마지 아키 작가 작품 좀 찾아줄래?",
    "entities": [
      [0, 6, "author"]
    ]
  },
  {
    "text": "R. C. 스프로울 저자의 책 소장 중인가요?",
    "entities": [
      [0, 10, "author"],
      [15, 16, "format"]
    ]
  },
  {
    "text": "도서관에 있는 앙투안 드 생텍쥐페리 작품 목록 볼 수 있어?",
    "entities": [
      [8, 19, "author"]
    ]
  },
  {
    "text": "룰루 밀러 소설이 도서관에 있는지 궁금해요",
    "entities": [
      [0, 5, "author"]
    ]
  },
  {
    "text": "이은희 저자 책 검색해줄 수 있어?",
    "entities": [
      [0, 3, "author"],
      [7, 8, "format"]
    ]
  },
  {
    "text": "도서관에 요즘 인기 많은 작가 중에 박보명의 책도 있을까요?",
    "entities": [
      [20, 23, "author"],
      [25, 26, "format"]
    ]
  },
  {
    "text": "그 김차차라는 분 책, 혹시 여기서도 볼 수 있나요?",
    "entities": [
      [2, 5, "author"],
      [10, 11, "format"]
    ]
  },
  {
    "text": "나는 제임스 해밀턴  책을 찾고 있는데, 도서관에 있을지 모르겠네",
    "entities": [
      [3, 10, "author"],
      [12, 13, "format"]
    ]
  },
  {
    "text": "리사 펠드먼 배럿이 집필한 책이 도서관에 비치되어 있는지요?",
    "entities": [
      [0, 9, "author"],
      [15, 16, "format"]
    ]
  },
  {
    "text": "도서관 자료 중에 찰스 로버트 다윈이라는 작가 책도 포함돼 있나요?",
    "entities": [
      [10, 19, "author"],
      [26, 27, "format"]
    ]
  },
  {
    "text": "조혜련 작가의 책을 예전에 읽었는데, 다시 찾아보려고요",
    "entities": [
      [0, 3, "author"],
      [8, 9, "format"]
    ]
  },
  {
    "text": "요즘 노무라 유스케 저자의 책에 빠졌는데, 여기도 있나요?",
    "entities": [
      [3, 10, "author"],
      [15, 16, "format"]
    ]
  },
  {
    "text": "혹시 도서관에 지미 송의 대표작이 소장되어 있습니까?",
    "entities": [
      [8, 12, "author"]
    ]
  },
  {
    "text": "오힘찬이 쓴 책이라면 어떤 게 있는지 알려줄 수 있어?",
    "entities": [
      [0, 3, "author"],
      [7, 8, "format"]
    ]
  },
  {
    "text": "도서관 서가에서 오오이시 나호 책을 보신 적 있나요?",
    "entities": [
      [9, 16, "author"],
      [17, 18, "format"]
    ]
  },
  {
    "text": "김태유의 문학 작품을 접하고 싶은데, 뭐가 있을까요?",
    "entities": [
      [0, 3, "author"]
    ]
  },
  {
    "text": "예전에 박태웅이 쓴 책을 빌렸는데, 아직 있을까?",
    "entities": [
      [4, 7, "author"],
      [11, 12, "format"]
    ]
  },
  {
    "text": "모리시타 수라는 분 책을 찾고 있는데, 도와주실 수 있나요?",
    "entities": [
      [0, 6, "author"],
      [11, 12, "format"]
    ]
  },
  {
    "text": "호카조노 타케루 책 말인데요, 도서관에 들어온 적 있나요?",
    "entities": [
      [0, 8, "author"],
      [9, 10, "format"]
    ]
  },
  {
    "text": "도서관 책 검색할 때 최지영 이름으로도 한번 찾아줄래요?",
    "entities": [
      [12, 15, "author"]
    ]
  },
  {
    "text": "도서관 자료 중에 칼 세이건이 저술한 책도 있을까요?",
    "entities": [
      [10, 15, "author"],
      [21, 22, "format"]
    ]
  },
  {
    "text": "이 도서관에서 C. S. 루이스 작품을 본 기억이 나는데요",
    "entities": [
      [8, 17, "author"]
    ]
  },
  {
    "text": "루이스 캐럴이 쓴 글 중에서 읽어볼 만한 책이 있을까요?",
    "entities": [
      [0, 6, "author"],
      [23, 24, "format"]
    ]
  },
  {
    "text": "호시노 미즈키라는 이름의 작가 책은 어떻게 검색하죠?",
    "entities": [
      [0, 7, "author"],
      [17, 18, "format"]
    ]
  },
  {
    "text": "안유석 저자 작품, 도서관에도 소장 중인지요?",
    "entities": [
      [0, 3, "author"]
    ]
  },
  {
    "text": "도서관에는 제인 오스틴처럼 유명한 작가 책도 많겠죠?",
    "entities": [
      [6, 12, "author"],
      [22, 23, "format"]
    ]
  },
  {
    "text": "하마지 아키 작가 책 읽어보고 싶은데, 있냐?",
    "entities": [
      [0, 6, "author"],
      [10, 11, "format"]
    ]
  },
  {
    "text": "최근에 원영 작가 책 찾는 사람이 많던데, 도서관에도 있나요?",
    "entities": [
      [4, 6, "author"],
      [10, 11, "format"]
    ]
  },
  {
    "text": "도서관에 들어온 신간 중에 지미 송 책도 포함되어 있나요?",
    "entities": [
      [15, 17, "author"],
      [9, 11, "book_property"],
      [20, 21, "format"]
    ]
  },
  {
    "text": "제가 요즘 관심 있는 작가가 이선 몰릭 인데, 혹시 책이 있나요?",
    "entities": [
      [16, 21, "author"],
      [29, 30, "format"]
    ]
  },
  {
    "text": "R. C. 스프로울의 수필집을 찾고 싶어요, 도서관에 비치돼 있을까요?",
    "entities": [
      [0, 10, "author"]
    ]
  },
  {
    "text": "예전에 봤던 진 웹스터 책이 생각나서 다시 찾고 싶은데요",
    "entities": [
      [7, 12, "author"],
      [13, 14, "format"]
    ]
  },
  {
    "text": "로널드 롤하이저의 저서가 도서관에 있는지 도와줄 수 있을까요?",
    "entities": [
      [0, 8, "author"],
      [10, 12, "format"]
    ]
  },
  {
    "text": "메리 셸리 작가 책을 찾아봐라",
    "entities": [
      [0, 5, "author"],
      [9, 10, "format"]
    ]
  },
  {
    "text": "아이다이로가 펴낸 책이 도서관에 입고된 거 있냐?",
    "entities": [
      [0, 5, "author"],
      [10, 11, "format"]
    ]
  },
  {
    "text": "김일환의 저서가 있는지 궁금해서요",
    "entities": [
      [0, 3, "author"],
      [5, 7, "format"]
    ]
  },
  {
    "text": "꿈틀이야, 장우석 작가 책이 있는지 확인해 주실 수 있나요?",
    "entities": [
      [6, 9, "author"],
      [13, 14, "format"]
    ]
  },
  {
    "text": "하마지 아키라는 작가의 이름이 익숙한데, 책 있나요?",
    "entities": [
      [0, 6, "author"],
      [23, 24, "format"]
    ]
  },
  {
    "text": "캐시 윌리스 책을 친구가 추천해줬는데 도서관에도 있으면 좋겠네요",
    "entities": [
      [0, 6, "author"],
      [7, 8, "format"]
    ]
  },
  {
    "text": "영끌남 저자의 대표작은 도서관에 비치돼 있습니까?",
    "entities": [
      [0, 3, "author"]
    ]
  },
  {
    "text": "도서관 자료실에서 캐시 윌리스 관련 도서를 찾을 수 있을까요?",
    "entities": [
      [10, 16, "author"],
      [20, 22, "format"]
    ]
  },
  {
    "text": "김재철이라는 작가 책은 아직 입고 전인가요?",
    "entities": [
      [0, 3, "author"],
      [10, 11, "format"]
    ]
  },
  {
    "text": "김직선이 저술한 자료를 찾고 싶은데 도와주세요",
    "entities": [
      [0, 3, "author"]
    ]
  },
  {
    "text": "박한슬의 문학작품 중 도서관에 있는 책 좀 보여줄 수 있나요?",
    "entities": [
      [0, 3, "author"]
    ]
  },














  {
    "text": "ISBN 9788965962896 도서 검색해줘",
    "entities": [
      [5, 18, "isbn"],
      [19, 21, "format"]
    ]
  },
  {
    "text": "청구기호 813.6 ㅎ219ㅂ 책 어디 있는지 알려줘",
    "entities": [[5, 16, "call_number"]]
  },
  {
    "text": "인공지능 관련 책 좀 보여줘",
    "entities": [[0, 4, "topic"]]
  },
  {
    "text": "코스모스 책이 어디에 꽂혀있어?",
    "entities": [[0, 4, "title"]]
  },
  {
    "text": "데미안 지금 대출할 수 있나요?",
    "entities": [[0, 3, "title"]]
  },
  {
    "text": "SF 소설 추천해 주세요.",
    "entities": [[0, 5, "category"]]
  },
  {
    "text": "비 오는 날 읽기 좋은 잔잔한 책 없을까?",
    "entities": [
      [0, 6, "mood"],
      [13, 16, "mood"]
    ]
  },
  {
    "text": "우주 탐험에 관한 책 추천해줘.",
    "entities": [[0, 5, "topic"]]
  },
  {
    "text": "사피엔스랑 비슷한 책 있으면 알려줘.",
    "entities": [[0, 4, "title"]]
  },
  {
    "text": "초등학생이 읽을 만한 역사책 추천 부탁해.",
    "entities": [
      [0, 4, "target_audience"],
      [12, 15, "category"]
    ]
  },
  {
    "text": "오늘 오후에 스터디룸 쓸 수 있는지 확인해줘.",
    "entities": [
      [0, 2, "date"],
      [3, 5, "timeOfDay"],
      [7, 11, "location"]
    ]
  },
  {
    "text": "내일 2시에 세미나실 예약할게요.",
    "entities": [
